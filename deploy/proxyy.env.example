# /etc/proxyy/proxyy.env — environment file for the systemd unit.
# Copy to /etc/proxyy/proxyy.env, edit, then `chmod 600 /etc/proxyy/proxyy.env`.

# Base domain. Subdomains under this resolve to tunnels (wildcard DNS A record
# must point at this VPS's public IP).
TUNNEL_DOMAIN=tun.proxyy.in

# Shared secret. Clients must pass --auth <this token> or set TUNNEL_AUTH_TOKEN.
# Generate: `openssl rand -hex 16`
TUNNEL_AUTH_TOKEN=replace-me-with-openssl-rand-hex-16

# Email used when registering with Let's Encrypt (for renewal-failure notices).
TUNNEL_ACME_EMAIL=krishnenduchatterjee25@gmail.com

# Where issued certs are cached on disk. Matches systemd's StateDirectory=proxyy.
TUNNEL_CERT_CACHE=/var/lib/proxyy/certs
