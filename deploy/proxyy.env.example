# /etc/proxyy/proxyy.env — environment file for the systemd unit.
# Copy to /etc/proxyy/proxyy.env, edit, then `chmod 600 /etc/proxyy/proxyy.env`.
#
# Most flags can be set either here (TUNNEL_*) or as CLI flags in the unit's
# ExecStart line. Flags on ExecStart take precedence.

# --- required ---

# Base domain. Subdomains under this resolve to tunnels. A wildcard DNS A
# record (`*.<this>`) must point at this VPS's public IP.
TUNNEL_DOMAIN=tun.proxyy.in

# Shared secret. Clients must pass --auth <this token> or set TUNNEL_AUTH_TOKEN.
# Generate: `openssl rand -hex 16`
TUNNEL_AUTH_TOKEN=replace-me-with-openssl-rand-hex-16

# Email registered with Let's Encrypt. They use it to email you when a cert
# is about to expire and renewal has failed.
TUNNEL_ACME_EMAIL=krishnenduchatterjee25@gmail.com

# --- optional, sensible defaults ---

# Where issued LE certs are cached on disk. Matches systemd's
# StateDirectory=proxyy directive in proxyy.service.
TUNNEL_CERT_CACHE=/var/lib/proxyy/certs

# Wrap the control listener (port 7000) in TLS using the same LE cert that
# serves the HTTPS subdomains. Clients must then connect with --tls. The
# bundled systemd unit already passes --control-tls on ExecStart, so this
# env var is only consulted if you remove that flag from the unit.
# TUNNEL_CONTROL_TLS=true

# Address overrides. The systemd unit sets these via ExecStart flags; you can
# override here if you're running outside systemd.
# TUNNEL_HTTPS_ADDR=:443
